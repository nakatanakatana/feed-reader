{
  "name": "tanstack-router-file-based",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "vite --port 3000",
    "dev:mock": "VITE_USE_MOCKS=true vite --port 3000",
    "build": "vite build",
    "lint": "tsc --noEmit && biome check .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "serve": "vite preview",
    "start": "vite",
    "analyze": "ANALYZE=true vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.11.0",
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-web": "2.1.1",
    "@opentelemetry/api": "1.9.0",
    "@opentelemetry/auto-instrumentations-web": "0.58.0",
    "@opentelemetry/context-zone": "1.26.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.53.0",
    "@opentelemetry/instrumentation": "0.53.0",
    "@opentelemetry/resources": "1.26.0",
    "@opentelemetry/sdk-trace-base": "1.26.0",
    "@opentelemetry/sdk-trace-web": "1.26.0",
    "@opentelemetry/semantic-conventions": "1.27.0",
    "@tanstack/query-db-collection": "1.0.30",
    "@tanstack/router-plugin": "1.166.9",
    "@tanstack/solid-db": "0.2.13",
    "@tanstack/solid-query": "5.90.26",
    "@tanstack/solid-router": "1.167.0",
    "markdown-it": "14.1.1",
    "postcss": "8.5.8",
    "solid-js": "1.9.11",
    "web-vitals": "5.1.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.7",
    "@bufbuild/protoc-gen-es": "2.11.0",
    "@pandacss/dev": "1.9.0",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.5.0",
    "@vitest/browser-playwright": "4.1.0",
    "@vitest/coverage-v8": "4.1.0",
    "fast-check": "4.6.0",
    "msw": "2.12.10",
    "playwright": "1.58.2",
    "typescript": "5.9.3",
    "vite": "^8.0.0",
    "vite-bundle-analyzer": "1.3.6",
    "vite-plugin-pwa": "1.2.0",
    "vite-plugin-solid": "2.11.11",
    "vitest": "4.1.0"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
