{
  "name": "tanstack-router-file-based",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "vite --port 3000",
    "dev:mock": "VITE_USE_MOCKS=true vite --port 3000",
    "build": "vite build",
    "lint": "tsc --noEmit && oxlint . && oxfmt --check .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "check": "oxfmt --write .",
    "serve": "vite preview",
    "start": "vite",
    "analyze": "ANALYZE=true vite build",
    "gen:openapi": "tsp compile api",
    "gen:api": "kubb generate && oxfmt --write frontend/src/lib/api/types-generated.ts frontend/src/lib/api/generated frontend/src/mocks/generated",
    "gen:api-types": "npm run gen:api",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:related": "vitest related"
  },
  "dependencies": {
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-web": "0.65.0",
    "@opentelemetry/context-zone": "2.9.0",
    "@opentelemetry/exporter-trace-otlp-http": "0.220.0",
    "@opentelemetry/instrumentation": "0.220.0",
    "@opentelemetry/resources": "2.9.0",
    "@opentelemetry/sdk-trace-base": "2.9.0",
    "@opentelemetry/sdk-trace-web": "2.9.0",
    "@opentelemetry/semantic-conventions": "1.43.0",
    "@tanstack/router-plugin": "1.168.19",
    "@tanstack/solid-query": "5.101.2",
    "@tanstack/solid-router": "1.170.17",
    "markdown-it": "14.3.0",
    "postcss": "8.5.18",
    "solid-js": "1.9.14",
    "web-vitals": "5.3.0"
  },
  "devDependencies": {
    "@kubb/cli": "^4.0.0",
    "@kubb/core": "^4.0.0",
    "@kubb/plugin-client": "^4.0.0",
    "@kubb/plugin-msw": "^4.0.0",
    "@kubb/plugin-oas": "^4.0.0",
    "@kubb/plugin-solid-query": "^4.0.0",
    "@kubb/plugin-ts": "^4.0.0",
    "@msw/data": "^1.1.6",
    "@pandacss/dev": "1.11.4",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.9.5",
    "@typespec/compiler": "^1.12.0",
    "@typespec/http": "^1.12.0",
    "@typespec/openapi3": "^1.12.0",
    "@vitest/browser-playwright": "4.1.10",
    "@vitest/coverage-v8": "4.1.10",
    "fast-check": "4.9.0",
    "jsdom": "^29.1.1",
    "msw": "2.15.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.69.0",
    "playwright": "1.61.1",
    "typescript": "7.0.2",
    "vite": "^8.0.0",
    "vite-bundle-analyzer": "1.3.8",
    "vite-plugin-pwa": "1.3.0",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.10"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
