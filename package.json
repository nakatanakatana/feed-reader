{
  "name": "tanstack-router-file-based",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "panda codegen",
    "dev": "vite --port 3000",
    "dev:mock": "VITE_USE_MOCKS=true vite --port 3000",
    "build": "vite build",
    "lint": "tsc --noEmit && biome check .",
    "format": "biome format . --write",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "serve": "vite preview",
    "start": "vite",
    "analyze": "ANALYZE=true vite build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@bufbuild/protobuf": "2.12.0",
    "@connectrpc/connect": "2.1.1",
    "@connectrpc/connect-web": "2.1.1",
    "@opentelemetry/api": "1.9.1",
    "@opentelemetry/auto-instrumentations-web": "0.63.0",
    "@opentelemetry/context-zone": "2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "0.218.0",
    "@opentelemetry/instrumentation": "0.218.0",
    "@opentelemetry/resources": "2.7.1",
    "@opentelemetry/sdk-trace-base": "2.7.1",
    "@opentelemetry/sdk-trace-web": "2.7.1",
    "@opentelemetry/semantic-conventions": "1.41.1",
    "@tanstack/query-db-collection": "1.0.38",
    "@tanstack/router-plugin": "1.168.10",
    "@tanstack/solid-db": "0.2.21",
    "@tanstack/solid-query": "5.100.14",
    "@tanstack/solid-router": "1.170.7",
    "markdown-it": "14.1.1",
    "postcss": "8.5.15",
    "solid-js": "1.9.13",
    "web-vitals": "5.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@bufbuild/protoc-gen-es": "2.12.0",
    "@pandacss/dev": "1.11.1",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.9.1",
    "@vitest/browser-playwright": "4.1.7",
    "@vitest/coverage-v8": "4.1.7",
    "fast-check": "4.8.0",
    "msw": "2.14.6",
    "playwright": "1.60.0",
    "typescript": "6.0.3",
    "vite": "^8.0.0",
    "vite-bundle-analyzer": "1.3.8",
    "vite-plugin-pwa": "1.3.0",
    "vite-plugin-solid": "2.11.12",
    "vitest": "4.1.7"
  },
  "overrides": {
    "vite-plugin-pwa": {
      "vite": "$vite"
    }
  },
  "msw": {
    "workerDirectory": [
      "public"
    ]
  }
}
