{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "types": ["vite-plus/test/globals", "vite/client", "vite-plugin-pwa/client", "node"],

    // General
    "jsx": "react-jsx",
    "jsxImportSource": "solid-js",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],

    // Modules
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,

    // Type Checking & Safety
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["frontend/src", "vite.config.ts", "*.config.ts"]
}
